# Public site URL (optional; safe to expose — bundled if prefixed with VITE_)
# VITE_SITE_URL=https://www.advancesafe.in

# Google reCAPTCHA v3 site key (optional). If set, the demo form loads reCAPTCHA and sends
# `recaptchaToken` in the JSON body — you MUST verify the token in Google Apps Script
# (or your API) using the secret key. Secret key never goes in VITE_ or the frontend.
# VITE_RECAPTCHA_SITE_KEY=

# Optional: Formspree (or compatible) form URL for blog newsletter JSON POST.
# If unset, “Subscribe Free” opens a mailto to advancesafesystem@gmail.com with the email prefilled.
# VITE_NEWSLETTER_FORM_URL=https://formspree.io/f/your_form_id
